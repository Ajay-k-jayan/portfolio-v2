{
  "rewrites": [
    { "source": "/((?!assets|sitemap.xml|robots.txt|og-image|favicon|site.webmanifest|Ajay_KJ.pdf|googledf|opensearch.xml|llms.txt|humans.txt|\\.well-known).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, no-cache, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "index, follow, max-image-preview:large, max-snippet:-1" },
        { "key": "Link", "value": "</sitemap.xml>; rel=\"sitemap\"; type=\"application/xml\"" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, no-cache, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "index, follow, max-image-preview:large, max-snippet:-1" }
      ]
    },
    {
      "source": "/(downloads|resume)",
      "headers": [
        { "key": "Cache-Control", "value": "public, no-cache, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/Ajay_KJ.pdf",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "X-Robots-Tag", "value": "index, follow" },
        { "key": "Content-Disposition", "value": "inline; filename=\"Ajay_KJ.pdf\"" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(sitemap.xml|robots.txt|opensearch.xml|llms.txt|llms-full.txt|humans.txt)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/.well-known/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(favicon.svg|site.webmanifest|og-image.png|og-image.svg|profile.jpg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
