# Public site origin (no trailing slash). Used for canonical URLs, Open Graph, sitemap, and robots.txt.
# Production default in vite.config.ts is https://ajaykj.vercel.app if this is unset.
# Override when using a custom domain, e.g. VITE_SITE_URL=https://www.yourdomain.com
VITE_SITE_URL=https://ajaykj.vercel.app

# Optional: Google Search Console HTML tag verification content value only (not the full tag).
# VITE_GOOGLE_SITE_VERIFICATION=your_verification_string_here

# Optional: override Vite pre-bundle cache directory (default: %LOCALAPPDATA%/potfolio-v2-vite-cache on Windows).
# VITE_CACHE_DIR=C:/dev-cache/potfolio-v2-vite
